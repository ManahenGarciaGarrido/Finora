# Environment Configuration
NODE_ENV=production

# Server Port (Render will provide this automatically)
PORT=3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters

# CORS Configuration (comma-separated list of allowed origins)
# Example: https://finora-app.com,https://www.finora-app.com
ALLOWED_ORIGINS=*

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database

# Email Configuration (SMTP)
# =================================
# Choose ONE of the following configurations:

# -----------------------------------
# OPTION 1: Gmail (Recommended for testing)
# -----------------------------------
# 1. Enable 2FA in Google Account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-char password below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# -----------------------------------
# OPTION 2: SendGrid (Recommended for production)
# -----------------------------------
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# -----------------------------------
# OPTION 3: MailHog (Local development only)
# -----------------------------------
# SMTP_HOST=mailhog
# SMTP_PORT=1025

# Email Settings
EMAIL_FROM_NAME=Finora
EMAIL_FROM=noreply@finora.com
EMAIL_REPLY_TO=support@finora.com

# Application URL (for email links)
APP_URL=https://api.finora.com

# Frontend URL (for password reset links)
# Development: Use the URL where your Flutter app is running
# Production: Use your deployed frontend URL
FRONTEND_URL=http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info

# Salt Edge Open Banking (RF-10 — Top 10 bancos españoles via screen scraping)
# Plan Community: GRATUITO para uso no comercial/educativo. Sin eIDAS ni licencia TPP.
# Cobertura ES: BBVA, Santander, CaixaBank, Sabadell, Bankinter, ING España,
#               Unicaja, Abanca, Kutxabank, Openbank y más.
#
# Pasos para activar:
#   1. Registro en https://www.saltedge.com/create_account
#   2. Ir al Dashboard → Settings → Keys → copiar App ID y Secret
#   3. En Dashboard → Settings → Callback URLs añadir:
#        {APP_URL}/api/v1/banks/callback
#   4. Solicitar acceso Community (no comercial): https://www.saltedge.com/products/account_information
#
# Sin credenciales → modo mock automático (flujo demo completo sin banco real).
SALTEDGE_APP_ID=
SALTEDGE_SECRET=
