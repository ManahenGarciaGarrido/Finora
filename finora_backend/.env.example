# Environment Configuration
NODE_ENV=production

# Server Port (Render will provide this automatically)
PORT=3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters

# CORS Configuration (comma-separated list of allowed origins)
# Example: https://finora-app.com,https://www.finora-app.com
ALLOWED_ORIGINS=*

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database

# Email Configuration (SMTP)
# =================================
# Choose ONE of the following configurations:

# -----------------------------------
# OPTION 1: Gmail (Recommended for testing)
# -----------------------------------
# 1. Enable 2FA in Google Account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-char password below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# -----------------------------------
# OPTION 2: SendGrid (Recommended for production)
# -----------------------------------
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# -----------------------------------
# OPTION 3: MailHog (Local development only)
# -----------------------------------
# SMTP_HOST=mailhog
# SMTP_PORT=1025

# Email Settings
EMAIL_FROM_NAME=Finora
EMAIL_FROM=noreply@finora.com
EMAIL_REPLY_TO=support@finora.com

# Application URL (for email links and Plaid Link callbacks)
# IMPORTANTE: usa SIEMPRE http:// en desarrollo local — nunca https://.
# Usar https:// con un servidor HTTP causa ERR_SSL_PROTOCOL_ERROR en el navegador.
#
# Desarrollo local:  APP_URL=http://68.221.27.85:3000
# Producción:        APP_URL=https://api.finora.com
APP_URL=http://68.221.27.85:3000

# Frontend URL (for password reset links)
# Development: Use the URL where your Flutter app is running
# Production: Use your deployed frontend URL
FRONTEND_URL=http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info

# ─── RF-10 / RF-11: Plaid Open Banking ───────────────────────────────────────
#
# Plaid permite conectar cuentas bancarias reales (PSD2 + OAuth).
# El mismo código funciona en sandbox y producción — solo cambian las claves.
#
# SANDBOX (gratis, inmediato):
#   1. Registro gratuito en https://dashboard.plaid.com (sin empresa ni licencia)
#   2. Team Settings → Keys → copiar client_id + sandbox secret
#   3. Credenciales de prueba: user_good / pass_good (cualquier institución sandbox)
#   4. No se mueve dinero real, todos los datos son ficticios
#
# PRODUCCIÓN:
#   1. Solicitar acceso de producción en Plaid Dashboard (requiere revisión)
#   2. Cambiar PLAID_ENV=production
#   3. Usar el production secret (el CLIENT_ID es el mismo en sandbox y producción)
#   4. Configurar webhook en Plaid Dashboard: POST /api/v1/banks/plaid-webhook
#
# SIN CREDENCIALES → modo MOCK automático:
#   - Cuentas y transacciones demo, sin llamadas a Plaid
#   - Ideal para demos, CI/CD y pruebas offline

# Entorno: sandbox | production
PLAID_ENV=sandbox

# Credenciales Plaid (ambas vacías = modo mock)
PLAID_CLIENT_ID=
PLAID_SECRET=

# ─── RF-14 / RF-21 / RF-22: Servicio de IA ───────────────────────────────────
# URL del microservicio Python de IA (finora-ai)
# En Docker Compose se resuelve automáticamente por nombre de servicio
# En desarrollo local: http://localhost:5001
AI_SERVICE_URL=http://ai:5001

# ─── RF-25: Google Gemini API (AI Assistant) ──────────────────────────────────
# API key for Google Gemini — used by the Flutter app at build time via
# --dart-define=GEMINI_API_KEY=<your_key>
# Leave empty to fall back to the local AI microservice.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=