{
  "name": "finora-backend",
  "version": "1.0.0",
  "description": "Finora API Backend - Secure REST API for financial management app",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --runInBand --forceExit"
  },
  "keywords": [
    "finora",
    "api",
    "express",
    "nodejs",
    "rest",
    "financial"
  ],
  "author": "Finora Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "pdf-parse": "^1.1.4",
    "pg": "^8.11.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "routes/**/*.js",
      "services/**/*.js",
      "middleware/**/*.js",
      "!services/saltedge.js",
      "!services/yapily.js",
      "!services/plaid.js",
      "!services/fcm.js",
      "!services/db.js",
      "!routes/banks.js",
      "!routes/export.js",
      "!routes/fiscal.js",
      "!routes/currency.js",
      "!routes/widget.js",
      "!routes/investments.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "lcov",
      "text"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "statements": 80,
        "functions": 80,
        "branches": 80
      }
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
